---
import BaseLayout from '../layouts/BaseLayout.astro';

const sectorCards = [
  {
    title: 'Industria y producción',
    description:
      'Las plantas industriales necesitan una PCI pensada para convivir con procesos continuos, zonas de riesgo y equipos críticos sin penalizar productividad.',
    bullets: [
      'Diseño e implantación por áreas de proceso, almacenamiento y servicios auxiliares.',
      'Mantenimiento coordinado con paradas técnicas y ventanas reales de intervención.',
      'Adecuación de instalaciones existentes con criterio de continuidad operativa.',
    ],
  },
  {
    title: 'Logística y almacenes',
    description:
      'En plataformas logísticas y centros de distribución, la prioridad es proteger stock, flujos y tiempos de servicio con sistemas fiables y fácil trazabilidad.',
    bullets: [
      'Soluciones adaptadas a grandes superficies, muelles, racks y rotación de mercancía.',
      'Planificación para actuar sin bloquear entradas, salidas o picking.',
      'Seguimiento documental claro para responsables de mantenimiento y operaciones.',
    ],
  },
  {
    title: 'Retail y centros comerciales',
    description:
      'El benchmark del sector insiste en un punto: la instalación PCI en retail debe garantizar seguridad y cumplimiento sin comprometer la experiencia del cliente ni la actividad comercial.',
    bullets: [
      'Actuaciones compatibles con horarios comerciales, aperturas y campañas.',
      'Mayor foco en evacuación, señalización y disponibilidad de equipos.',
      'Respuesta ágil para tiendas, cadenas y espacios comerciales multiubicación.',
    ],
  },
  {
    title: 'Hoteles y edificios de pública concurrencia',
    description:
      'Hoteles, residencias y edificios con alta ocupación necesitan una estrategia especialmente sensible a la evacuación, la compartimentación y la continuidad del servicio.',
    bullets: [
      'Intervenciones por fases para reducir impacto en huéspedes y operación.',
      'Coordinación entre mantenimiento, dirección y explotación del edificio.',
      'Sistemas preparados para ocupación variable y exigencia documental constante.',
    ],
  },
  {
    title: 'Oficinas, terciario y edificios corporativos',
    description:
      'En entornos terciarios el valor está en mantener orden técnico, revisiones periódicas y documentación útil para property managers, facilities y dirección.',
    bullets: [
      'Mantenimiento estable con trazabilidad y visibilidad de incidencias.',
      'Regularización de instalaciones y planificación de mejoras por prioridad.',
      'Un interlocutor técnico claro para varios perfiles de decisión.',
    ],
  },
  {
    title: 'Hospitalario, data center y entornos críticos',
    description:
      'Los referentes del benchmark suelen destacar estas verticales por su criticidad: aquí la rapidez de detección, la continuidad del activo y el control técnico pesan más que en una instalación estándar.',
    bullets: [
      'Evaluación más precisa del riesgo y de la criticidad de cada zona.',
      'Mayor exigencia de fiabilidad, redundancia y planificación.',
      'Soporte documental y técnico para entornos altamente auditables.',
    ],
  },
];

const benchmarkSignals = [
  {
    title: 'Contenido más específico por vertical',
    text: 'La competencia mejor posicionada no habla de una solución genérica: nombra sectores concretos y aterriza necesidades reales de cada actividad.',
  },
  {
    title: 'Promesa operativa clara',
    text: 'Industria, logística, retail y hotelería responden mejor cuando el mensaje explica cómo se implanta o mantiene la PCI sin frenar el negocio.',
  },
  {
    title: 'Prueba de experiencia aplicable',
    text: 'Los players de referencia utilizan sectores y proyectos para transmitir especialización, contexto y capacidad de ejecución.',
  },
  {
    title: 'Interlinking natural con servicios',
    text: 'La página sectorial funciona mejor cuando conecta con instalación, mantenimiento, adecuación normativa y contacto sin duplicar discursos.',
  },
];

const sectorNeeds = [
  {
    title: 'Continuidad de actividad',
    text: 'Planificamos la implantación o el mantenimiento para minimizar paradas, interferencias y cuellos de botella sobre la operativa del centro.',
  },
  {
    title: 'Cumplimiento con criterio técnico',
    text: 'No se trata solo de cumplir sobre el papel, sino de que la instalación responda de verdad al riesgo del edificio y a su uso diario.',
  },
  {
    title: 'Trazabilidad y documentación',
    text: 'Centralizamos revisiones, incidencias y actuaciones para que mantenimiento, prevención y dirección tengan visibilidad real.',
  },
  {
    title: 'Escalabilidad por centro o red',
    text: 'Si la empresa opera varias ubicaciones, ayudamos a ordenar prioridades y mantener un criterio homogéneo entre instalaciones.',
  },
];

const process = [
  {
    step: '01',
    title: 'Entendemos el contexto del sector',
    text: 'Revisamos el tipo de actividad, la criticidad del activo, el ritmo operativo y el punto de partida de la instalación antes de proponer soluciones.',
  },
  {
    step: '02',
    title: 'Definimos prioridades y alcance',
    text: 'Aterrizamos qué conviene instalar, mantener, corregir o regularizar primero para reducir riesgo y avanzar con una hoja de ruta clara.',
  },
  {
    step: '03',
    title: 'Ejecutamos con seguimiento',
    text: 'Implantamos y documentamos cada actuación para que la empresa mantenga control técnico, operativo y documental en el tiempo.',
  },
];

const faqs = [
  {
    question: '¿Qué sectores necesitan una estrategia PCI más específica?',
    answer:
      'Industria, logística, retail, hotelería y entornos críticos suelen requerir un planteamiento más adaptado porque cambian la ocupación, la continuidad del negocio, la criticidad de los activos y la forma de intervenir.',
  },
  {
    question: '¿Podéis adaptar el servicio a empresas con varios centros?',
    answer:
      'Sí. Podemos priorizar por sedes, homogeneizar criterios técnicos y ordenar actuaciones para que la empresa gane visibilidad y consistencia entre instalaciones.',
  },
  {
    question: '¿La página sectorial sustituye a la de servicios?',
    answer:
      'No. La complementa. La página de sectores ayuda a que cada perfil se identifique antes, y desde ahí se conecta con los servicios PCI más adecuados para su necesidad concreta.',
  },
  {
    question: '¿Qué valor aporta frente a un mensaje genérico?',
    answer:
      'Reduce incertidumbre, mejora la relevancia del mensaje y hace que la conversación comercial empiece desde un contexto más útil: operativa, riesgo, implantación y documentación.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: 'https://gepprotect.netlify.app/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Sectores',
      item: 'https://gepprotect.netlify.app/sectores/',
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<BaseLayout
  title="Sectores PCI para empresas | Soluciones por tipo de actividad"
  description="Soluciones de protección contra incendios para industria, logística, retail, hoteles, terciario y entornos críticos con enfoque técnico, operativo y sectorial."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="container py-6 sm:py-8">
    <div class="rounded-[2rem] border border-red-100 bg-white/95 p-6 shadow-sm sm:p-8 lg:p-10">
      <nav aria-label="Breadcrumb" class="text-sm text-slate-500">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/" class="transition hover:text-[#e1062c]">Inicio</a></li>
          <li aria-hidden="true" class="text-red-300">/</li>
          <li class="font-medium text-slate-700">Sectores</li>
        </ol>
      </nav>

      <div class="mt-6">
        <div>
          <p class="brand-eyebrow">Sectores PCI</p>
          <h1 class="mt-3 max-w-4xl text-[1rem] font-extrabold tracking-tight text-slate-900 sm:text-[1.375rem] lg:text-[2.125rem] lg:leading-[1.08]">
            Protección contra incendios adaptada al contexto real de cada sector.
          </h1>
          <p class="mt-4 max-w-3xl text-base leading-7 text-slate-700 sm:text-lg sm:leading-8">
            Hemos rehecho esta página como una interior de conversión, con una estructura más parecida a Servicios y un
            mensaje mucho más útil para usuarios que comparan proveedores. El contenido se apoya en patrones que se
            repiten en el benchmark competitivo: especialización por vertical, foco en continuidad operativa,
            implantación por fases y claridad documental.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/contacto" class="brand-button">Solicitar revisión por sector</a>
            <a href="/servicios" class="rounded-full border border-red-200 px-5 py-2.5 text-sm font-semibold text-[#e1062c] transition hover:bg-red-50">Ver servicios</a>
          </div>
        </div>
      </div>

      <div class="mt-8 grid gap-3 sm:grid-cols-3">
        <div class="rounded-2xl border border-red-100 bg-white p-4 shadow-sm">
          <p class="text-sm font-semibold text-slate-900">Sectores con más demanda</p>
          <p class="mt-2 text-sm leading-6 text-slate-700">Industria, logística, retail, hotelería y terciario concentran los discursos sectoriales más repetidos en el benchmark.</p>
        </div>
        <div class="rounded-2xl border border-red-100 bg-white p-4 shadow-sm">
          <p class="text-sm font-semibold text-slate-900">Mensaje orientado a operativa</p>
          <p class="mt-2 text-sm leading-6 text-slate-700">El contenido pone el foco en implantación, mantenimiento y continuidad del negocio, no solo en catálogo técnico.</p>
        </div>
        <div class="rounded-2xl border border-red-100 bg-white p-4 shadow-sm">
          <p class="text-sm font-semibold text-slate-900">Mejor lectura comercial</p>
          <p class="mt-2 text-sm leading-6 text-slate-700">Cada bloque ayuda al usuario a verse reflejado antes de pasar a servicios, delegaciones o contacto.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container pb-12 sm:pb-16">
    <div class="grid gap-8 lg:grid-cols-[1fr_0.9fr] lg:items-start">
      <div>
        <p class="brand-eyebrow">Sectores en los que trabajamos</p>
        <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
          Una propuesta sectorial pensada para que cada empresa entienda rápido cómo aplicamos la PCI a su actividad.
        </h2>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-700">
          En lugar de hablar de forma genérica, ordenamos la propuesta por verticales donde la necesidad cambia de
          verdad: producción, logística, atención al público, ocupación intensiva o entornos especialmente críticos.
        </p>
        <div class="mt-8 grid gap-4">
          {sectorCards.map((sector) => (
            <article class="brand-card">
              <h3 class="text-xl font-bold text-slate-900">{sector.title}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-700">{sector.description}</p>
              <ul class="mt-4 grid gap-2 text-sm text-slate-700">
                {sector.bullets.map((bullet) => (
                  <li class="flex gap-3">
                    <span class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-red-100 text-[11px] font-bold text-[#b40422]">✓</span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>

      <div class="space-y-6 lg:sticky lg:top-24">
        <div class="overflow-hidden rounded-[2rem] border border-red-100 bg-white shadow-sm">
          <img
            src="/landing/home-servicios-pci.webp"
            alt="Instalación y revisión de sistemas de protección contra incendios en un entorno profesional"
            class="h-full min-h-[280px] w-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="rounded-[2rem] border border-red-100 bg-red-50/70 p-6">
          <h3 class="text-lg font-bold text-slate-900">Qué espera encontrar el usuario sectorial</h3>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-slate-700">
            <li class="rounded-2xl bg-white p-4 shadow-sm">Un proveedor que entienda su operativa y no solo el producto PCI.</li>
            <li class="rounded-2xl bg-white p-4 shadow-sm">Una explicación clara de cómo instalar o mantener sin frenar la actividad.</li>
            <li class="rounded-2xl bg-white p-4 shadow-sm">Pruebas de experiencia aplicables a su tipo de edificio o negocio.</li>
            <li class="rounded-2xl bg-white p-4 shadow-sm">Siguientes pasos sencillos hacia revisión técnica, adecuación o mantenimiento.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="container pb-12 sm:pb-16">
    <div class="rounded-[2rem] border border-red-100 bg-red-50/60 p-8">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div class="overflow-hidden rounded-[1.5rem] border border-red-100 bg-white shadow-sm">
          <img
            src="/landing/empresas-instalaciones-contra-incendios-2.webp"
            alt="Profesionales revisando una instalación de protección contra incendios en una empresa"
            class="h-full min-h-[300px] w-full object-cover"
            loading="lazy"
          />
        </div>
        <div>
          <p class="brand-eyebrow">Lo que nos dice el benchmark</p>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
            Las páginas sectoriales que mejor resuelven la intención de búsqueda combinan especialización, claridad y utilidad comercial.
          </h2>
          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            {benchmarkSignals.map((item) => (
              <article class="brand-card">
                <h3 class="text-lg font-bold text-slate-900">{item.title}</h3>
                <p class="mt-3 text-sm leading-6 text-slate-700">{item.text}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container pb-12 sm:pb-16">
    <div class="rounded-[2rem] border border-red-100 bg-white p-8 shadow-sm">
      <div class="max-w-3xl">
        <p class="brand-eyebrow">Qué cambia de un sector a otro</p>
        <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
          Aunque la base técnica sea la misma, la prioridad de negocio no lo es.
        </h2>
        <p class="mt-5 text-lg leading-8 text-slate-700">
          Esta sección aterriza los criterios que más pesan cuando una empresa evalúa a un proveedor PCI con una lógica
          más cercana a compra real que a una simple visita informativa.
        </p>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        {sectorNeeds.map((item) => (
          <article class="brand-card h-full">
            <h3 class="text-lg font-bold text-slate-900">{item.title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-700">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="container pb-12 sm:pb-16">
    <div class="rounded-[2rem] border border-red-100 bg-white p-8 shadow-sm">
      <div class="max-w-3xl">
        <p class="brand-eyebrow">Cómo trabajamos</p>
        <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
          Un proceso claro para traducir el riesgo sectorial en una actuación priorizada y ejecutable.
        </h2>
      </div>
      <div class="mt-8 grid gap-4 lg:grid-cols-3">
        {process.map((item) => (
          <article class="rounded-2xl border border-slate-200 p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#b40422]">Paso {item.step}</p>
            <h3 class="mt-3 text-lg font-bold text-slate-900">{item.title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-700">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="container pb-12 sm:pb-16">
    <div class="rounded-[2rem] border border-red-100 bg-white p-8 shadow-sm">
      <div class="max-w-3xl">
        <p class="brand-eyebrow">Preguntas frecuentes</p>
        <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
          Dudas habituales cuando una empresa busca soluciones PCI según su sector.
        </h2>
      </div>
      <div class="mt-8 grid gap-4">
        {faqs.map((faq) => (
          <article class="rounded-2xl border border-red-100 bg-red-50/40 p-6">
            <h3 class="text-lg font-bold text-slate-900">{faq.question}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-700">{faq.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="container pb-16 sm:pb-24">
    <div class="rounded-[2rem] bg-[#141414] px-8 py-10 text-white shadow-xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-red-200">Solicitar valoración</p>
      <h2 class="mt-4 max-w-3xl text-3xl font-extrabold tracking-tight sm:text-4xl">
        Si quieres adaptar la protección contra incendios a la realidad de tu sector, podemos ayudarte a definir el siguiente paso.
      </h2>
      <p class="mt-5 max-w-2xl text-base leading-7 text-slate-300">
        Cuéntanos si necesitas instalar, mantener, adecuar o revisar una instalación en industria, logística, retail,
        hoteles, terciario o un entorno crítico. Te ayudaremos a priorizar con criterio técnico y visión operativa.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contacto" class="brand-button">Solicitar revisión por sector</a>
        <a href="/delegaciones" class="rounded-full border border-white/20 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-white/10">Ver cobertura y delegaciones</a>
      </div>
    </div>
  </section>
</BaseLayout>
