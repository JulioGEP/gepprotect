---
import BaseLayout from '../layouts/BaseLayout.astro';

const quickLinks = [
  {
    title: 'Servicios PCI',
    href: '/servicios',
    text: 'Instalación, mantenimiento y mejora continua de sistemas de protección contra incendios.',
  },
  {
    title: 'Sectores',
    href: '/sectores',
    text: 'Soluciones específicas para industria, logística, retail, hotelero y comunidades.',
  },
  {
    title: 'Normativa',
    href: '/normativa',
    text: 'Guías prácticas de RIPCI, CTE y normas UNE para tomar decisiones con seguridad.',
  },
  {
    title: 'Contacto',
    href: '/contacto',
    text: 'Solicita inspección técnica, mantenimiento preventivo o propuesta personalizada.',
  },
];
---

<BaseLayout
  title="GEP Protect | Protección contra incendios para empresas"
  description="Base de diseño de GEP Protect adaptada a la guía de marca GEPCO Formación y al estilo visual del ecosistema del grupo."
>
  <section class="container py-14 sm:py-20">
    <p class="brand-eyebrow">Grupo GEP · Seguridad PCI</p>
    <h1 class="mt-4 max-w-4xl text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
      Protección contra incendios con estética de marca unificada para todo el ecosistema GEP.
    </h1>
    <p class="mt-6 max-w-3xl text-lg text-slate-700">
      Esta base visual toma como referencia <strong>gepcoformacion.es</strong> para definir color principal,
      jerarquía tipográfica, uso de bloques limpios y llamadas a la acción en rojo corporativo.
    </p>
    <div class="mt-8 flex flex-wrap items-center gap-3">
      <a href="/contacto" class="brand-button">Solicitar inspección PCI</a>
      <a href="/servicios" class="rounded-full border border-red-200 px-5 py-2.5 text-sm font-semibold text-[#e1062c] transition hover:bg-red-50">Ver servicios</a>
    </div>
  </section>

  <section class="container pb-14 sm:pb-20">
    <div class="grid gap-5 sm:grid-cols-2">
      {quickLinks.map((item) => (
        <article class="brand-card">
          <h2 class="text-xl font-bold text-slate-900">{item.title}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-700">{item.text}</p>
          <a href={item.href} class="mt-4 inline-flex text-sm font-semibold text-[#e1062c] hover:text-[#b40422]">
            Acceder →
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
