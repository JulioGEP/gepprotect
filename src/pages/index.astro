---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { services, sectors } from '../data/site';

const metrics = [
  { value: '15+', label: 'Años protegiendo empresas' },
  { value: '500+', label: 'Clientes activos' },
  { value: '2000+', label: 'Instalaciones auditadas' },
  { value: '100%', label: 'Cumplimiento normativo' }
];

const highlights = ['Certificados ISO 9001', 'Empresas instaladoras autorizadas', 'RIPCI actualizado'];
const processSteps = [
  { title: 'Contacto', description: 'Te escuchamos y validamos tu situación actual.' },
  { title: 'Evaluación técnica', description: 'Analizamos tu instalación y necesidades.' },
  { title: 'Instalación', description: 'Ejecutamos con técnicos certificados.' }
];

const testimonials = [
  {
    text: 'Excelente servicio de asesoría y mantenimiento. El equipo fue rápido y profesional en auditorías.',
    name: 'Carlos Martínez',
    role: 'Director de Operaciones'
  },
  {
    text: 'Han reducido el riesgo normativo y mejorado la seguridad. Trabajo muy ordenado y transparente.',
    name: 'Ana Rodríguez',
    role: 'Responsable de Prevención'
  },
  {
    text: 'Recomendable al 100%. Respuesta ágil, documentación clara y gran atención postventa.',
    name: 'Miguel Ibáñez',
    role: 'Facility Manager'
  }
];
---
<BaseLayout title="Instalación y mantenimiento PCI en Madrid | GEP Protect" description="Instalación y mantenimiento PCI para cumplir normativa con técnicos especializados y respuesta rápida.">
  <section class="relative left-1/2 right-1/2 -mx-[50vw] w-screen overflow-hidden bg-[#111] text-white">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_right,#E4032D_0%,transparent_45%)] opacity-60"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black via-black/80 to-black/45"></div>
    <div class="relative mx-auto grid w-full max-w-6xl gap-8 px-4 py-18 lg:grid-cols-2 lg:py-24">
      <div>
        <span class="inline-flex rounded-full border border-[#E4032D]/40 bg-[#E4032D]/15 px-3 py-1 text-xs font-semibold text-[#ff6a82]">Expertos en Protección Contra Incendios</span>
        <h1 class="mt-5 max-w-xl text-4xl font-bold leading-tight md:text-5xl">Cumple la normativa PCI sin riesgos ni sanciones</h1>
        <p class="mt-4 max-w-xl text-zinc-300">Instalación y mantenimiento de sistemas contra incendios con certificación garantizada. Protegemos tu empresa y evitamos problemas legales.</p>
        <p class="mt-2 text-xs text-zinc-400">+500 empresas confían en nosotros · Respuesta en menos de 24h</p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="#cta-final" class="rounded-md bg-[#E4032D] px-5 py-3 text-sm font-semibold text-white">Solicitar visita técnica</a>
          <a href="/contacto/" class="rounded-md border border-white/35 px-5 py-3 text-sm font-semibold">Hablar con un técnico</a>
        </div>
      </div>
      <div class="hidden min-h-[300px] rounded-xl border border-white/10 bg-[linear-gradient(135deg,#1a1a1a,#282828)] shadow-2xl lg:block"></div>
    </div>
  </section>

  <section class="py-14 text-center">
    <p class="mx-auto max-w-3xl text-zinc-600">Somos un partner en la protección contra incendios para empresas de cualquier tamaño. Cumplimos con toda la normativa vigente y garantizamos máxima seguridad para tu empresa.</p>
    <div class="mt-10 grid gap-5 md:grid-cols-4">
      {metrics.map((metric) => (
        <article class="rounded-xl border border-zinc-200 bg-white p-5">
          <p class="text-3xl font-bold text-[#222]">{metric.value}</p>
          <p class="text-sm text-zinc-500">{metric.label}</p>
        </article>
      ))}
    </div>
    <div class="mt-7 flex flex-wrap items-center justify-center gap-2">
      {highlights.map((item) => <span class="rounded-md border border-zinc-200 bg-white px-3 py-2 text-xs">{item}</span>)}
    </div>
  </section>

  <section class="relative left-1/2 right-1/2 -mx-[50vw] w-screen bg-[#f5f5f6] py-16">
    <div class="mx-auto w-full max-w-6xl px-4">
      <header class="text-center">
        <h2 class="text-4xl font-bold text-[#252525]">Nuestros servicios</h2>
        <p class="mt-3 text-zinc-500">Soluciones completas de protección contra incendios para todo tipo de instalaciones.</p>
      </header>
      <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <article class="rounded-xl border border-zinc-200 bg-white p-6">
            <p class="text-2xl">{service.icon}</p>
            <h3 class="mt-4 text-xl font-semibold">{service.title}</h3>
            <p class="mt-2 text-sm text-zinc-500">{service.short}</p>
            <a href={`/servicios/${service.slug}/`} class="mt-3 inline-block text-sm font-semibold text-[#E4032D]">Ver solución →</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16">
    <header class="text-center">
      <h2 class="text-4xl font-bold text-[#252525]">Sectores que atendemos</h2>
      <p class="mt-3 text-zinc-500">Especialistas en protección contra incendios para diversos sectores y tipos de instalaciones.</p>
    </header>
    <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {sectors.map((sector) => (
        <article class="rounded-xl border border-zinc-200 bg-white p-5 text-center">
          <p class="text-2xl">{sector.icon}</p>
          <h3 class="mt-3 font-semibold">{sector.title}</h3>
          <p class="mt-2 text-sm text-zinc-500">{sector.short}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="relative left-1/2 right-1/2 -mx-[50vw] w-screen bg-[#0f0f0f] py-16 text-white">
    <div class="mx-auto grid w-full max-w-6xl items-center gap-8 px-4 lg:grid-cols-2">
      <div>
        <span class="inline-flex rounded-full border border-[#E4032D]/40 bg-[#E4032D]/15 px-3 py-1 text-xs font-semibold text-[#ff6a82]">Cumplimiento Normativo</span>
        <h2 class="mt-4 text-4xl font-bold">¿Tu empresa cumple la normativa PCI?</h2>
        <p class="mt-4 text-zinc-300">Te ayudamos a verificar si tu instalación cumple con la normativa vigente y a corregir cualquier riesgo antes de una inspección o un problema legal.</p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="#cta-final" class="rounded-md bg-[#E4032D] px-5 py-3 text-sm font-semibold">Comprobar instalación</a>
          <a href="/contacto/" class="rounded-md border border-white/30 px-5 py-3 text-sm font-semibold">Ver servicios</a>
        </div>
      </div>
      <div class="min-h-[250px] rounded-xl border border-white/10 bg-[linear-gradient(160deg,#111,#272727)]"></div>
    </div>
  </section>

  <section class="py-16 text-center">
    <h2 class="text-4xl font-bold text-[#252525]">¿Cómo trabajamos?</h2>
    <p class="mt-3 text-zinc-500">Un proceso simple y transparente en tres pasos.</p>
    <div class="mt-12 grid gap-10 md:grid-cols-3">
      {processSteps.map((step, index) => (
        <article>
          <p class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-[#E4032D]/10 font-bold text-[#E4032D]">{index + 1}</p>
          <h3 class="mt-4 text-xl font-semibold">{step.title}</h3>
          <p class="mt-2 text-sm text-zinc-500">{step.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="py-16">
    <header class="text-center">
      <h2 class="text-4xl font-bold text-[#252525]">Lo que dicen nuestros clientes</h2>
      <p class="mt-3 text-zinc-500">La confianza y satisfacción de nuestros clientes nos avalan.</p>
    </header>
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {testimonials.map((item) => (
        <article class="rounded-xl border border-zinc-200 bg-white p-6">
          <p class="text-[#E4032D]">★★★★★</p>
          <p class="mt-4 text-sm text-zinc-600">“{item.text}”</p>
          <p class="mt-5 font-semibold">{item.name}</p>
          <p class="text-xs text-[#E4032D]">{item.role}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="cta-final" class="relative left-1/2 right-1/2 -mx-[50vw] w-screen bg-[#E4032D] py-16 text-white">
    <div class="mx-auto w-full max-w-3xl px-4 text-center">
      <h2 class="text-4xl font-bold">Verifica el cumplimiento de tu instalación PCI con un técnico especializado</h2>
      <p class="mt-3 text-white/90">Tu informe de cumplimiento normativo y plan correctivo mejora en menos de 24 h.</p>
      <div class="mx-auto mt-8 max-w-xl rounded-xl bg-white p-5 text-left text-[#222] shadow-xl">
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>
