---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { services, sectors } from '../data/site';

const metrics = [
  { value: '15+', label: 'Años protegiendo empresas' },
  { value: '500+', label: 'Clientes activos' },
  { value: '2.000+', label: 'Instalaciones auditadas' },
  { value: '100%', label: 'Cumplimiento normativo' }
];

const highlights = [
  { label: 'Certificados ISO 9001', icon: '✓' },
  { label: 'Empresas instaladoras autorizadas', icon: '✓' },
  { label: 'RIPCI actualizado', icon: '✓' }
];

const processSteps = [
  { title: 'Contacto', description: 'Te escuchamos y validamos tu situación actual con una llamada sin compromiso.' },
  { title: 'Evaluación técnica', description: 'Nuestro equipo analiza tu instalación in situ y detecta cualquier incumplimiento.' },
  { title: 'Instalación y certificación', description: 'Ejecutamos con técnicos certificados y emitimos la documentación RIPCI.' }
];

const testimonials = [
  {
    text: 'Excelente servicio de asesoría y mantenimiento. El equipo fue rápido y profesional en auditorías.',
    name: 'Carlos Martínez',
    role: 'Director de Operaciones',
    avatar: 'https://i.pravatar.cc/64?img=11'
  },
  {
    text: 'Han reducido el riesgo normativo y mejorado la seguridad. Trabajo muy ordenado y transparente.',
    name: 'Ana Rodríguez',
    role: 'Responsable de Prevención',
    avatar: 'https://i.pravatar.cc/64?img=5'
  },
  {
    text: 'Recomendable al 100%. Respuesta ágil, documentación clara y gran atención postventa.',
    name: 'Miguel Ibáñez',
    role: 'Facility Manager',
    avatar: 'https://i.pravatar.cc/64?img=15'
  }
];
---
<BaseLayout title="Instalación y mantenimiento PCI en Madrid | GEP Protect" description="Instalación y mantenimiento PCI para cumplir normativa con técnicos especializados y respuesta rápida.">

  {/* ── HERO ── */}
  <section class="relative left-1/2 right-1/2 -mx-[50vw] w-screen overflow-hidden bg-[#111] text-white">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_right,#E4032D_0%,transparent_45%)] opacity-60"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black via-black/80 to-black/45"></div>
    <div class="relative mx-auto grid w-full max-w-6xl gap-8 px-4 py-18 lg:grid-cols-2 lg:py-24">
      <div class="flex flex-col justify-center">
        <span class="inline-flex w-fit rounded-full border border-[#E4032D]/40 bg-[#E4032D]/15 px-3 py-1 text-xs font-semibold text-[#ff6a82]">
          Expertos en Protección Contra Incendios
        </span>
        <h1 class="mt-5 max-w-xl text-4xl font-bold leading-tight md:text-5xl">
          Cumple la normativa PCI sin riesgos ni sanciones
        </h1>
        <p class="mt-4 max-w-lg text-zinc-300">
          Instalación y mantenimiento de sistemas contra incendios con certificación garantizada. Protegemos tu empresa y evitamos problemas legales.
        </p>
        <div class="mt-2 flex flex-wrap items-center gap-4 text-xs text-zinc-400">
          <span class="flex items-center gap-1"><span class="text-green-400">●</span> +500 empresas confían en nosotros</span>
          <span class="flex items-center gap-1"><span class="text-green-400">●</span> Respuesta en menos de 24h</span>
        </div>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="#cta-final" class="rounded-md bg-[#E4032D] px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-[#E4032D]/30 transition hover:bg-[#c70426]">
            Solicitar visita técnica
          </a>
          <a href="/contacto/" class="rounded-md border border-white/30 px-5 py-3 text-sm font-semibold transition hover:border-white/60">
            Hablar con un técnico
          </a>
        </div>
      </div>
      <div class="hidden overflow-hidden rounded-2xl border border-white/10 shadow-2xl lg:block">
        <img
          src="https://picsum.photos/seed/pci-hero/800/560"
          alt="Técnico instalando sistema de protección contra incendios"
          class="h-full w-full object-cover opacity-85"
          loading="eager"
          width="800"
          height="560"
        />
      </div>
    </div>
  </section>

  {/* ── MÉTRICAS + CERTIFICACIONES ── */}
  <section class="py-14">
    <p class="mx-auto max-w-2xl text-center text-zinc-500">
      Somos partner de referencia en protección contra incendios para empresas de cualquier tamaño. Cumplimos con toda la normativa vigente y garantizamos máxima seguridad.
    </p>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 md:grid-cols-4">
      {metrics.map((metric) => (
        <article class="rounded-xl border border-zinc-100 bg-white p-6 text-center shadow-sm">
          <p class="text-3xl font-bold text-[#222]">{metric.value}</p>
          <p class="mt-1 text-sm text-zinc-500">{metric.label}</p>
        </article>
      ))}
    </div>
    <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
      {highlights.map((item) => (
        <span class="flex items-center gap-1.5 rounded-lg border border-zinc-200 bg-white px-4 py-2 text-xs font-medium shadow-sm">
          <span class="text-[#E4032D] font-bold">{item.icon}</span>
          {item.label}
        </span>
      ))}
    </div>
  </section>

  {/* ── SERVICIOS ── */}
  <section class="relative left-1/2 right-1/2 -mx-[50vw] w-screen bg-[#f5f5f6] py-16">
    <div class="mx-auto w-full max-w-6xl px-4">
      <header class="text-center">
        <span class="inline-block rounded-full bg-[#E4032D]/10 px-3 py-1 text-xs font-semibold text-[#E4032D]">Soluciones PCI</span>
        <h2 class="mt-3 text-4xl font-bold text-[#252525]">Nuestros servicios</h2>
        <p class="mt-3 text-zinc-500">Soluciones completas de protección contra incendios para todo tipo de instalaciones.</p>
      </header>
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <article class="group overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm transition hover:shadow-md hover:-translate-y-0.5">
            <div class="aspect-[16/9] overflow-hidden">
              <img
                src={service.image}
                alt={service.title}
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                loading="lazy"
                width="600"
                height="340"
              />
            </div>
            <div class="p-6">
              <h3 class="text-lg font-semibold text-[#222]">{service.title}</h3>
              <p class="mt-2 text-sm text-zinc-500">{service.short}</p>
              <a href={`/servicios/${service.slug}/`} class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-[#E4032D] hover:underline">
                Ver solución
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ── SECTORES ── */}
  <section class="py-16">
    <header class="text-center">
      <span class="inline-block rounded-full bg-[#E4032D]/10 px-3 py-1 text-xs font-semibold text-[#E4032D]">Especialización</span>
      <h2 class="mt-3 text-4xl font-bold text-[#252525]">Sectores que atendemos</h2>
      <p class="mt-3 text-zinc-500">Especialistas en protección contra incendios para diversos sectores y tipos de instalaciones.</p>
    </header>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {sectors.map((sector) => (
        <article class="group overflow-hidden rounded-2xl border border-zinc-200 bg-white shadow-sm transition hover:shadow-md hover:-translate-y-0.5">
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={sector.image}
              alt={sector.title}
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              loading="lazy"
              width="600"
              height="420"
            />
          </div>
          <div class="p-5">
            <h3 class="font-semibold text-[#222]">{sector.title}</h3>
            <p class="mt-1.5 text-sm text-zinc-500">{sector.short}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  {/* ── COMPLIANCE CTA ── */}
  <section class="relative left-1/2 right-1/2 -mx-[50vw] w-screen overflow-hidden bg-[#0f0f0f] py-16 text-white">
    <div class="mx-auto grid w-full max-w-6xl items-center gap-8 px-4 lg:grid-cols-2">
      <div class="flex flex-col justify-center">
        <span class="inline-flex w-fit rounded-full border border-[#E4032D]/40 bg-[#E4032D]/15 px-3 py-1 text-xs font-semibold text-[#ff6a82]">
          Cumplimiento Normativo
        </span>
        <h2 class="mt-4 text-4xl font-bold">¿Tu empresa cumple la normativa PCI?</h2>
        <p class="mt-4 max-w-lg text-zinc-300">
          Te ayudamos a verificar si tu instalación cumple con la normativa vigente y a corregir cualquier riesgo antes de una inspección o un problema legal.
        </p>
        <ul class="mt-5 space-y-2">
          {['Auditoría gratuita de tu instalación actual', 'Informe de cumplimiento en menos de 24 h', 'Plan correctivo detallado sin coste'].map(item => (
            <li class="flex items-center gap-2 text-sm text-zinc-300">
              <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-[#E4032D] text-[10px] font-bold text-white">✓</span>
              {item}
            </li>
          ))}
        </ul>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#cta-final" class="rounded-md bg-[#E4032D] px-5 py-3 text-sm font-semibold transition hover:bg-[#c70426]">
            Comprobar instalación
          </a>
          <a href="/servicios/" class="rounded-md border border-white/30 px-5 py-3 text-sm font-semibold transition hover:border-white/60">
            Ver servicios
          </a>
        </div>
      </div>
      <div class="hidden overflow-hidden rounded-2xl border border-white/10 shadow-2xl lg:block">
        <img
          src="https://picsum.photos/seed/pci-compliance/800/540"
          alt="Inspección y cumplimiento normativo PCI"
          class="h-full w-full object-cover opacity-75"
          loading="lazy"
          width="800"
          height="540"
        />
      </div>
    </div>
  </section>

  {/* ── CÓMO TRABAJAMOS ── */}
  <section class="py-16 text-center">
    <span class="inline-block rounded-full bg-[#E4032D]/10 px-3 py-1 text-xs font-semibold text-[#E4032D]">Proceso</span>
    <h2 class="mt-3 text-4xl font-bold text-[#252525]">¿Cómo trabajamos?</h2>
    <p class="mt-3 text-zinc-500">Un proceso simple y transparente en tres pasos.</p>
    <div class="mt-12 grid gap-8 md:grid-cols-3">
      {processSteps.map((step, index) => (
        <article class="relative rounded-2xl border border-zinc-100 bg-white p-8 shadow-sm">
          <p class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-[#E4032D] text-lg font-bold text-white shadow-md shadow-[#E4032D]/30">
            {index + 1}
          </p>
          <h3 class="text-xl font-semibold text-[#222]">{step.title}</h3>
          <p class="mt-2 text-sm text-zinc-500">{step.description}</p>
          {index < processSteps.length - 1 && (
            <div class="absolute -right-4 top-1/2 hidden -translate-y-1/2 text-zinc-200 md:block">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          )}
        </article>
      ))}
    </div>
  </section>

  {/* ── TESTIMONIOS ── */}
  <section class="relative left-1/2 right-1/2 -mx-[50vw] w-screen bg-[#f5f5f6] py-16">
    <div class="mx-auto w-full max-w-6xl px-4">
      <header class="text-center">
        <span class="inline-block rounded-full bg-[#E4032D]/10 px-3 py-1 text-xs font-semibold text-[#E4032D]">Testimonios</span>
        <h2 class="mt-3 text-4xl font-bold text-[#252525]">Lo que dicen nuestros clientes</h2>
        <p class="mt-3 text-zinc-500">La confianza y satisfacción de nuestros clientes nos avalan.</p>
      </header>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {testimonials.map((item) => (
          <article class="flex flex-col rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
            <p class="text-sm text-[#E4032D] tracking-wider">★★★★★</p>
            <p class="mt-4 flex-1 text-sm leading-relaxed text-zinc-600">"{item.text}"</p>
            <div class="mt-6 flex items-center gap-3 border-t border-zinc-100 pt-5">
              <img
                src={item.avatar}
                alt={item.name}
                class="h-10 w-10 rounded-full object-cover ring-2 ring-zinc-100"
                loading="lazy"
                width="40"
                height="40"
              />
              <div>
                <p class="text-sm font-semibold text-[#222]">{item.name}</p>
                <p class="text-xs text-[#E4032D]">{item.role}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ── CTA FINAL + FORMULARIO ── */}
  <section id="cta-final" class="relative left-1/2 right-1/2 -mx-[50vw] w-screen overflow-hidden bg-[#E4032D] py-16 text-white">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,#ff3d5c_0%,transparent_60%)] opacity-40"></div>
    <div class="relative mx-auto w-full max-w-3xl px-4 text-center">
      <span class="inline-block rounded-full border border-white/30 bg-white/10 px-3 py-1 text-xs font-semibold">Respuesta garantizada en 24h</span>
      <h2 class="mt-4 text-4xl font-bold">
        Verifica el cumplimiento de tu instalación PCI con un técnico especializado
      </h2>
      <p class="mt-3 text-white/85">
        Recibe tu informe de cumplimiento normativo y plan correctivo en menos de 24 h.
      </p>
      <div class="mx-auto mt-8 max-w-xl rounded-2xl bg-white p-6 text-left text-[#222] shadow-2xl">
        <ContactForm />
      </div>
    </div>
  </section>

</BaseLayout>
