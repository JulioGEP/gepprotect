---
import BaseLayout from '../layouts/BaseLayout.astro';

const painPoints = [
  'Diseño, instalación y mantenimiento PCI adaptados al riesgo real de cada instalación.',
  'Cumplimiento técnico y documental para afrontar inspecciones, auditorías y revisiones con más control.',
  'Respuesta ágil para industria, logística, retail, hoteles, edificios terciarios y espacios de pública concurrencia.',
];

const services = [
  {
    title: 'Ingeniería e instalación PCI',
    text: 'Definimos e implantamos sistemas de detección, alarma, extinción y señalización para que cada instalación quede dimensionada según su actividad, ocupación y nivel de riesgo.',
  },
  {
    title: 'Mantenimiento preventivo y correctivo',
    text: 'Programamos revisiones, pruebas funcionales y reposiciones para mantener la instalación operativa, reducir incidencias y asegurar el estado de los equipos cuando más importa.',
  },
  {
    title: 'Adecuación normativa y soporte documental',
    text: 'Ordenamos la parte técnica y documental de la PCI con informes, registros y seguimiento para que puedas demostrar el estado de tu instalación con criterio y trazabilidad.',
  },
];

const differentiators = [
  {
    title: 'Menos incertidumbre',
    text: 'Analizamos el punto de partida, priorizamos riesgos y definimos actuaciones concretas para que sepas qué hacer, cuándo hacerlo y por qué.',
  },
  {
    title: 'Más continuidad operativa',
    text: 'Trabajamos para que la protección contra incendios no sea solo un requisito, sino una parte activa de la seguridad y la continuidad de tu actividad.',
  },
  {
    title: 'Un servicio con seguimiento',
    text: 'Cada intervención queda revisada, registrada y enfocada a que responsables de mantenimiento, prevención y gerencia tengan visibilidad real.',
  },
];

const sectors = [
  'Naves industriales y centros de producción',
  'Plataformas logísticas y almacenes',
  'Locales comerciales y retail',
  'Hoteles y edificios de pública concurrencia',
  'Oficinas y edificios terciarios',
  'Centros educativos y sanitarios',
];

const faqs = [
  {
    question: '¿Qué resuelve GEP Protect?',
    answer:
      'Ayuda a empresas y responsables técnicos a implantar, mantener y adecuar sus sistemas PCI para reducir riesgo, cumplir con sus obligaciones y trabajar con más tranquilidad.',
  },
  {
    question: '¿Cuándo tiene sentido pedir una revisión?',
    answer:
      'Cuando necesitas instalar un sistema nuevo, actualizar una instalación existente, preparar una inspección, corregir incidencias o mejorar el control sobre el mantenimiento.',
  },
  {
    question: '¿Qué puedes esperar del servicio?',
    answer:
      'Diagnóstico técnico, plan de actuación, ejecución, mantenimiento y soporte documental para que la protección contra incendios esté alineada con la realidad de tu edificio y tu actividad.',
  },
];
---

<BaseLayout
  title="GEP Protect | Protección contra incendios para empresas"
  description="Instalación, mantenimiento y adecuación normativa PCI para empresas e instalaciones que necesitan cumplir, prevenir y operar con seguridad."
>
  <section class="container grid gap-10 py-14 sm:py-20 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
    <div>
      <p class="brand-eyebrow">Protección contra incendios para empresas</p>
      <h1 class="mt-4 max-w-4xl text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
        Instalación, mantenimiento y adecuación PCI para trabajar con más seguridad.
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-700">
        En GEP Protect ayudamos a empresas que necesitan una protección contra incendios bien ejecutada,
        bien mantenida y bien documentada. Diseñamos e implantamos soluciones PCI adaptadas a cada instalación
        para reducir riesgo, facilitar el cumplimiento normativo y dar continuidad a la actividad.
      </p>
      <ul class="mt-8 grid gap-3 text-sm leading-6 text-slate-700 sm:grid-cols-1">
        {painPoints.map((item) => (
          <li class="flex gap-3 rounded-2xl border border-red-100 bg-white/90 p-4 shadow-sm">
            <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-red-100 text-xs font-bold text-[#b40422]">✓</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contacto" class="brand-button">Solicitar revisión PCI</a>
        <a href="/servicios" class="rounded-full border border-red-200 px-5 py-2.5 text-sm font-semibold text-[#e1062c] transition hover:bg-red-50">Ver servicios</a>
      </div>
    </div>

    <figure class="overflow-hidden rounded-[2rem] border border-red-100 bg-white p-4 shadow-lg">
      <div class="relative aspect-[4/3] overflow-hidden rounded-[1.5rem] bg-red-50 lg:min-h-[420px]">
        <img
          src="/landing/empresa-proteccion-incendios.webp"
          alt="Sistema de protección contra incendios en una instalación empresarial"
          class="h-full w-full object-cover object-center"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
      <figcaption class="mt-4 space-y-2 text-sm text-slate-600">
        <p>
          La protección contra incendios en España se encuentra respaldada por un marco normativo sólido y exigente, diseñado para <strong>asegurar la seguridad</strong> en edificaciones e instalaciones industriales.
        </p>
        <p>
          El Reglamento de Seguridad contra Incendios en Establecimientos Industriales (RSCIEI) establece medidas específicas para prevenir incendios en instalaciones industriales, mientras que el <strong>Reglamento de Instalaciones de Protección Contra Incendios (RIPCI)</strong> define requisitos técnicos para sistemas de protección contra incendios en edificios.
        </p>
      </figcaption>
    </figure>
  </section>

  <section class="container pb-14 sm:pb-20">
    <div class="grid gap-6 rounded-[2rem] border border-red-100 bg-white p-8 shadow-sm lg:grid-cols-3">
      {differentiators.map((item) => (
        <article>
          <h2 class="text-lg font-bold text-slate-900">{item.title}</h2>
          <p class="mt-3 text-sm leading-6 text-slate-700">{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="container pb-14 sm:pb-20">
    <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
      <div>
        <p class="brand-eyebrow">Servicios PCI</p>
        <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
          Una cobertura técnica completa para prevenir, cumplir y actuar a tiempo.
        </h2>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-700">
          Reunimos en un mismo servicio la parte de ingeniería, la implantación en campo, el mantenimiento y el soporte documental necesario para que la protección contra incendios tenga sentido técnico y operativo.
        </p>
        <div class="mt-8 grid gap-4">
          {services.map((service) => (
            <article class="brand-card">
              <h3 class="text-lg font-bold text-slate-900">{service.title}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-700">{service.text}</p>
            </article>
          ))}
        </div>
      </div>

      <figure class="rounded-[2rem] border border-red-100 bg-white p-4 shadow-lg">
        <img
          src="/landing/home-servicios-pci.webp"
          alt="Instalación técnica de servicios PCI"
          class="h-full w-full rounded-[1.5rem] object-cover"
        />
        <figcaption class="mt-3 text-sm text-slate-600">
          <strong class="text-slate-900">Servicios PCI en entorno técnico real.</strong>
          La imagen refuerza la cobertura de ingeniería, implantación y mantenimiento sobre instalaciones de protección contra incendios.
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="container pb-14 sm:pb-20">
    <div class="grid gap-8 rounded-[2rem] border border-red-100 bg-red-50/60 p-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
      <figure class="order-2 rounded-[2rem] border border-red-100 bg-white p-4 shadow-sm lg:order-1">
        <img
          src="/landing/empresas-instalaciones-contra-incendios-2.webp"
          alt="Técnico realizando mantenimiento en instalación contra incendios"
          class="h-full w-full rounded-[1.5rem] object-cover"
        />
      </figure>

      <div class="order-1 lg:order-2">
        <p class="brand-eyebrow">Mantenimiento y seguimiento</p>
        <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
          Mantener la instalación al día es mantener el riesgo bajo control.
        </h2>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-700">
          Revisamos equipos, detectamos desviaciones, programamos actuaciones y dejamos constancia documental de cada intervención para que puedas anticiparte a incidencias y afrontar revisiones con más seguridad.
        </p>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <div class="brand-card">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#b40422]">Cumplimiento</p>
            <p class="mt-3 text-sm leading-6 text-slate-700">Planificación, registros y trazabilidad para que la instalación esté preparada ante inspecciones, auditorías y controles internos.</p>
          </div>
          <div class="brand-card">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#b40422]">Disponibilidad</p>
            <p class="mt-3 text-sm leading-6 text-slate-700">Sistemas más fiables, menos improvisación y una respuesta técnica orientada a proteger personas, activos y continuidad de negocio.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container pb-14 sm:pb-20">
    <div class="grid gap-8 lg:grid-cols-[1fr_0.95fr] lg:items-center">
      <div>
        <p class="brand-eyebrow">Sectores</p>
        <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
          Soluciones PCI adaptadas a instalaciones donde el riesgo no se gestiona igual.
        </h2>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-700">
          Cada entorno exige prioridades diferentes. Por eso adaptamos la respuesta técnica al uso del edificio, la ocupación, la operativa y el nivel de exposición para diseñar medidas coherentes con la realidad de cada cliente.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          {sectors.map((sector) => (
            <span class="rounded-full border border-red-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm">
              {sector}
            </span>
          ))}
        </div>
      </div>

      <figure class="rounded-[2rem] border border-red-100 bg-white p-4 shadow-lg">
        <img
          src="/landing/importancia-plan-autoproteccion.webp"
          alt="Equipo técnico revisando un plan de autoprotección en una instalación industrial"
          class="h-full w-full rounded-[1.5rem] object-cover"
          loading="lazy"
        />
      </figure>
    </div>
  </section>

  <section class="container pb-14 sm:pb-20">
    <div class="rounded-[2rem] border border-red-100 bg-white p-8 shadow-sm">
      <div class="max-w-3xl">
        <p class="brand-eyebrow">Qué puede esperar tu empresa</p>
        <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
          Respuestas claras para decidir con criterio antes del primer contacto.
        </h2>
      </div>
      <div class="mt-8 grid gap-4 lg:grid-cols-3">
        {faqs.map((faq) => (
          <article class="rounded-2xl border border-slate-200 p-5">
            <h3 class="text-base font-bold text-slate-900">{faq.question}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-700">{faq.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="container pb-16 sm:pb-24">
    <div class="rounded-[2rem] bg-[#141414] px-8 py-10 text-white shadow-xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-red-200">Contacto</p>
      <h2 class="mt-4 max-w-3xl text-3xl font-extrabold tracking-tight sm:text-4xl">
        Si necesitas una empresa PCI que ejecute bien, mantenga con criterio y documente cada actuación, estamos preparados para ayudarte.
      </h2>
      <p class="mt-5 max-w-2xl text-base leading-7 text-slate-300">
        Solicita una revisión de tus instalaciones, una propuesta de mantenimiento o una valoración técnica para adecuación normativa.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contacto" class="brand-button">Solicitar revisión PCI</a>
        <a href="/delegaciones" class="rounded-full border border-white/20 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-white/10">Ver cobertura y delegaciones</a>
      </div>
    </div>
  </section>
</BaseLayout>
