---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Reporting WooCommerce Compras | GEP Protect"
  description="Sincronización manual de pedidos completados de WooCommerce"
>
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="rounded-[2rem] border border-red-100 bg-white p-8 shadow-sm">
      <h1 class="text-3xl font-semibold text-slate-900">WooCommerce Compras</h1>
      <p class="mt-3 text-sm text-slate-600">
        Pulsa <strong>Actualizar</strong> para consultar WooCommerce e incorporar en la base de datos los pedidos
        completados que aún no existan (desde el 01/01/2026).
      </p>

      <div class="mt-6 flex flex-wrap items-center gap-3">
        <button
          id="actualizar-pedidos"
          type="button"
          class="rounded-full bg-[#e1062c] px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-[#bd0524] disabled:cursor-not-allowed disabled:opacity-60"
        >
          Actualizar
        </button>
        <span id="estado-sync" class="text-sm text-slate-600" aria-live="polite"></span>
      </div>

      <pre id="detalle-sync" class="mt-6 hidden overflow-auto rounded-2xl border border-red-100 bg-red-50/40 p-4 text-xs text-slate-700"></pre>
    </div>
  </section>

  <script>
    const boton = document.getElementById('actualizar-pedidos');
    const estado = document.getElementById('estado-sync');
    const detalle = document.getElementById('detalle-sync');

    async function sincronizarPedidos() {
      if (!boton || !estado || !detalle) return;

      boton.disabled = true;
      estado.textContent = 'Actualizando pedidos...';
      detalle.classList.add('hidden');
      detalle.textContent = '';

      try {
        const respuesta = await fetch('/.netlify/functions/woocommerce-sync', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
        });

        const data = await respuesta.json();

        if (!respuesta.ok) {
          throw new Error(data?.error || 'No se pudo completar la actualización.');
        }

        estado.textContent = data.message || 'Sincronización completada.';
        detalle.textContent = JSON.stringify(data, null, 2);
        detalle.classList.remove('hidden');
      } catch (error) {
        estado.textContent = error instanceof Error ? error.message : 'Error inesperado al sincronizar.';
      } finally {
        boton.disabled = false;
      }
    }

    boton?.addEventListener('click', sincronizarPedidos);
  </script>
</BaseLayout>
