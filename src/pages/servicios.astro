---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceCards = [
  {
    title: 'Ingeniería e instalación',
    description:
      'Proyectamos e implantamos sistemas PCI con criterio técnico y visión operativa, para que la instalación responda a las necesidades reales del negocio desde el inicio.',
    bullets: [
      'Diseño y dimensionamiento de sistemas según actividad y riesgo.',
      'Implantación en obra nueva, reforma o ampliación.',
      'Puesta en marcha coordinada con la operativa del centro.',
    ],
  },
  {
    title: 'Mantenimiento preventivo y correctivo',
    description:
      'Mantenemos los sistemas en condiciones de uso mediante revisiones periódicas, pruebas, sustituciones y actuaciones correctivas documentadas.',
    bullets: [
      'Calendario de mantenimiento con trazabilidad.',
      'Detección anticipada de incidencias y desviaciones.',
      'Soporte técnico para responsables de mantenimiento y operaciones.',
    ],
  },
  {
    title: 'Adecuación normativa y regularización',
    description:
      'Auditamos instalaciones existentes y definimos prioridades para adecuarlas al contexto normativo y operativo de la empresa.',
    bullets: [
      'Diagnóstico técnico del punto de partida.',
      'Plan de adecuación por fases y prioridades.',
      'Acompañamiento ante revisiones, auditorías e inspecciones.',
    ],
  },
  {
    title: 'Gestión documental y soporte continuo',
    description:
      'Te ayudamos a mantener la documentación ordenada y útil para la toma de decisiones, no solo archivada.',
    bullets: [
      'Informes y registros de mantenimiento.',
      'Seguimiento de actuaciones pendientes y mejoras.',
      'Visión global para dirección, mantenimiento y prevención.',
    ],
  },
];

const businessValue = [
  {
    title: 'Menos incertidumbre técnica',
    text: 'Tienes claro qué necesita la instalación, qué prioridad tiene cada actuación y cuál es el siguiente paso razonable.',
  },
  {
    title: 'Más capacidad de respuesta',
    text: 'Los sistemas se mantienen operativos para responder cuando el edificio, las personas y la actividad lo necesitan.',
  },
  {
    title: 'Más control documental',
    text: 'La información clave queda ordenada para facilitar seguimiento interno, revisiones externas e inspecciones.',
  },
  {
    title: 'Un interlocutor técnico único',
    text: 'Centralizas instalación, mantenimiento y adecuación con un partner que entiende el impacto sobre la operativa del negocio.',
  },
];

const process = [
  {
    step: '01',
    title: 'Revisión de la necesidad',
    text: 'Analizamos el tipo de instalación, el uso del edificio, el momento de la empresa y el problema real que hay que resolver.',
  },
  {
    step: '02',
    title: 'Propuesta priorizada',
    text: 'Definimos alcance, prioridades, tiempos y líneas de actuación para que puedas decidir con visibilidad y criterio.',
  },
  {
    step: '03',
    title: 'Ejecución y seguimiento',
    text: 'Implantamos, mantenemos y documentamos cada actuación para que la protección contra incendios se sostenga en el tiempo.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: 'https://gepprotect.netlify.app/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Servicios',
      item: 'https://gepprotect.netlify.app/servicios/',
    },
  ],
};
---

<BaseLayout
  title="Servicios PCI para empresas | Instalación, mantenimiento y adecuación"
  description="Servicios de protección contra incendios para empresas que necesitan instalar, mantener, adecuar o regularizar sus sistemas con enfoque técnico y de negocio."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <section class="container py-6 sm:py-8">
    <div class="rounded-[2rem] border border-red-100 bg-white/95 p-6 shadow-sm sm:p-8 lg:p-10">
      <nav aria-label="Breadcrumb" class="text-sm text-slate-500">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/" class="transition hover:text-[#e1062c]">Inicio</a></li>
          <li aria-hidden="true" class="text-red-300">/</li>
          <li class="font-medium text-slate-700">Servicios</li>
        </ol>
      </nav>

      <div class="mt-6">
        <div>
          <p class="brand-eyebrow">Servicios PCI</p>
          <h1 class="mt-3 max-w-4xl text-[1rem] font-extrabold tracking-tight text-slate-900 sm:text-[1.375rem] lg:text-[2.125rem] lg:leading-[1.08]">
            Servicios de protección contra incendios pensados para responder a una necesidad real de negocio.
          </h1>
          <p class="mt-4 max-w-3xl text-base leading-7 text-slate-700 sm:text-lg sm:leading-8">
            En GEP Protect ayudamos a empresas que necesitan instalar, mantener, corregir o adecuar sus sistemas PCI
            con un enfoque práctico: proteger personas e instalaciones, reducir riesgo operativo y mantener el control
            técnico y documental.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/contacto" class="brand-button">Solicitar revisión PCI</a>
            <a href="/delegaciones" class="rounded-full border border-red-200 px-5 py-2.5 text-sm font-semibold text-[#e1062c] transition hover:bg-red-50">Ver delegaciones</a>
          </div>
        </div>
      </div>

      <div class="mt-8 grid gap-3 sm:grid-cols-3">
        <div class="rounded-2xl border border-red-100 bg-white p-4 shadow-sm">
          <p class="text-sm font-semibold text-slate-900">Instalación y adecuación</p>
          <p class="mt-2 text-sm leading-6 text-slate-700">Soluciones adaptadas al uso del edificio y al nivel de riesgo.</p>
        </div>
        <div class="rounded-2xl border border-red-100 bg-white p-4 shadow-sm">
          <p class="text-sm font-semibold text-slate-900">Mantenimiento continuado</p>
          <p class="mt-2 text-sm leading-6 text-slate-700">Revisiones y correctivos para sostener la operatividad.</p>
        </div>
        <div class="rounded-2xl border border-red-100 bg-white p-4 shadow-sm">
          <p class="text-sm font-semibold text-slate-900">Soporte técnico</p>
          <p class="mt-2 text-sm leading-6 text-slate-700">Más claridad para dirección, mantenimiento y prevención.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="container pb-12 sm:pb-16">
    <div class="grid gap-8 lg:grid-cols-[1fr_0.9fr] lg:items-start">
      <div>
        <p class="brand-eyebrow">Qué hacemos</p>
        <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
          Una propuesta de servicio clara para necesidades PCI que no pueden esperar.
        </h2>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-700">
          Estructuramos el servicio para que la empresa entienda qué solución necesita, qué impacto tiene y cómo
          avanzar sin perder tiempo en mensajes genéricos o información irrelevante.
        </p>
        <div class="mt-8 grid gap-4">
          {serviceCards.map((service) => (
            <article class="brand-card">
              <h3 class="text-xl font-bold text-slate-900">{service.title}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-700">{service.description}</p>
              <ul class="mt-4 grid gap-2 text-sm text-slate-700">
                {service.bullets.map((bullet) => (
                  <li class="flex gap-3">
                    <span class="mt-1 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-red-100 text-[11px] font-bold text-[#b40422]">✓</span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>

      <div class="space-y-6 lg:sticky lg:top-24">
        <div class="overflow-hidden rounded-[2rem] border border-red-100 bg-white shadow-sm">
          <img
            src="/landing/empresas-instalaciones-contra-incendios-2.webp"
            alt="Instalación de sistemas de protección contra incendios en entorno empresarial"
            class="h-full min-h-[280px] w-full object-cover"
            loading="lazy"
          />
        </div>
        <div class="rounded-[2rem] border border-red-100 bg-red-50/70 p-6">
          <h3 class="text-lg font-bold text-slate-900">Lo que necesita una empresa cuando busca este servicio</h3>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-slate-700">
            <li class="rounded-2xl bg-white p-4 shadow-sm">Saber si la instalación actual responde al riesgo real.</li>
            <li class="rounded-2xl bg-white p-4 shadow-sm">Tener un plan claro para instalar, mantener o corregir.</li>
            <li class="rounded-2xl bg-white p-4 shadow-sm">Evitar improvisación ante incidencias o revisiones.</li>
            <li class="rounded-2xl bg-white p-4 shadow-sm">Contar con documentación útil para seguimiento y control.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="container pb-12 sm:pb-16">
    <div class="rounded-[2rem] border border-red-100 bg-red-50/60 p-8">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div class="overflow-hidden rounded-[1.5rem] border border-red-100 bg-white shadow-sm">
          <img
            src="/landing/importancia-plan-autoproteccion.webp"
            alt="Equipo técnico revisando documentación y planificación de protección contra incendios"
            class="h-full min-h-[300px] w-full object-cover"
            loading="lazy"
          />
        </div>
        <div>
          <p class="brand-eyebrow">Valor para el negocio</p>
          <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
            La protección contra incendios no solo va de cumplir: va de operar con menos riesgo y más control.
          </h2>
          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            {businessValue.map((item) => (
              <article class="brand-card">
                <h3 class="text-lg font-bold text-slate-900">{item.title}</h3>
                <p class="mt-3 text-sm leading-6 text-slate-700">{item.text}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container pb-12 sm:pb-16">
    <div class="rounded-[2rem] border border-red-100 bg-white p-8 shadow-sm">
      <div class="max-w-3xl">
        <p class="brand-eyebrow">Cómo trabajamos</p>
        <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">
          Un proceso sencillo para convertir una necesidad urgente en una actuación ordenada.
        </h2>
      </div>
      <div class="mt-8 grid gap-4 lg:grid-cols-3">
        {process.map((item) => (
          <article class="rounded-2xl border border-slate-200 p-6">
            <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#b40422]">Paso {item.step}</p>
            <h3 class="mt-3 text-lg font-bold text-slate-900">{item.title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-700">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="container pb-16 sm:pb-24">
    <div class="rounded-[2rem] bg-[#141414] px-8 py-10 text-white shadow-xl">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-red-200">Solicitar valoración</p>
      <h2 class="mt-4 max-w-3xl text-3xl font-extrabold tracking-tight sm:text-4xl">
        Si tu empresa necesita instalar, mantener o regularizar su protección contra incendios, podemos ayudarte a ordenar el siguiente paso.
      </h2>
      <p class="mt-5 max-w-2xl text-base leading-7 text-slate-300">
        Cuéntanos qué está ocurriendo: una instalación pendiente, un mantenimiento mejorable, una adecuación necesaria o una revisión próxima. Te ayudaremos a enfocar la actuación con criterio técnico y visión de negocio.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/contacto" class="brand-button">Solicitar revisión PCI</a>
        <a href="/delegaciones" class="rounded-full border border-white/20 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-white/10">Ver cobertura y delegaciones</a>
      </div>
    </div>
  </section>
</BaseLayout>
