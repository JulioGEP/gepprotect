---
import BaseLayout from '../layouts/BaseLayout.astro';

const quickNotes = [
  'Texto de ejemplo para explicar en una línea qué ocurre al enviar el formulario.',
  'Texto aleatorio para reforzar cercanía, rapidez de respuesta o revisión inicial.',
  'Texto placeholder para indicar que después aquí añadiremos el mensaje definitivo.',
];

const delegations = [
  {
    city: 'Madrid',
    area: 'Zona centro',
    text: 'Texto random sobre esta delegación para sustituir más adelante. Aquí podemos hablar de cobertura, tipo de clientes o tiempos de respuesta.',
  },
  {
    city: 'Barcelona',
    area: 'Cataluña',
    text: 'Texto de prueba para describir esta delegación. Después podremos añadir información real, servicios destacados o sectores principales.',
  },
  {
    city: 'Valencia',
    area: 'Levante',
    text: 'Texto temporal para esta delegación. Sirve como hueco para una explicación breve y fácil de escanear.',
  },
  {
    city: 'Sevilla',
    area: 'Andalucía',
    text: 'Texto placeholder para futura redacción. Aquí luego podemos incluir ciudades cercanas, cobertura o una frase comercial sencilla.',
  },
];
---

<BaseLayout
  title="Contacto | Propuesta sencilla"
  description="Propuesta muy sencilla para la página de contacto con formulario básico y bloque inferior de delegaciones."
>
  <section class="container py-8 sm:py-10">
    <div class="rounded-[2rem] border border-red-100 bg-white p-6 shadow-sm sm:p-8 lg:p-10">
      <p class="brand-eyebrow">Contacto</p>
      <div class="mt-4 grid gap-8 lg:grid-cols-[minmax(0,1.05fr)_22rem] lg:items-start">
        <div>
          <h1 class="max-w-3xl text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl lg:text-[3.1rem] lg:leading-[1.05]">
            Una página de contacto muy sencilla para captar consultas sin complicaciones
          </h1>
          <p class="mt-4 max-w-2xl text-base leading-7 text-slate-700 sm:text-lg sm:leading-8">
            Texto random de introducción para sustituir después. La idea aquí es explicar en pocas líneas qué puede hacer el usuario, por qué debería escribirnos y qué tipo de ayuda encontrará.
          </p>

          <div class="mt-6 grid gap-3 sm:grid-cols-3">
            {quickNotes.map((note) => (
              <article class="rounded-2xl border border-red-100 bg-red-50/70 p-4 text-sm leading-6 text-slate-700">
                {note}
              </article>
            ))}
          </div>
        </div>

        <aside class="rounded-[1.75rem] border border-red-100 bg-red-50 p-5 sm:p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#b40422]">Contacto rápido</p>
          <div class="mt-4 space-y-4 text-sm leading-6 text-slate-700">
            <div>
              <p class="font-semibold text-slate-900">Teléfono</p>
              <p>900 000 000</p>
            </div>
            <div>
              <p class="font-semibold text-slate-900">Email</p>
              <p>hola@empresa-ejemplo.com</p>
            </div>
            <div>
              <p class="font-semibold text-slate-900">Horario</p>
              <p>Lunes a viernes · 09:00 a 18:00</p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="container pb-12 sm:pb-16">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_24rem]">
      <div class="rounded-[2rem] border border-red-100 bg-white p-6 shadow-sm sm:p-8">
        <div class="max-w-2xl">
          <p class="brand-eyebrow">Formulario</p>
          <h2 class="mt-3 text-2xl font-extrabold tracking-tight text-slate-900 sm:text-3xl">
            Un formulario corto, claro y fácil de rellenar
          </h2>
          <p class="mt-4 text-sm leading-7 text-slate-700 sm:text-base">
            Más texto de ejemplo para sustituir. Aquí podríamos añadir una frase breve sobre el tiempo de respuesta o sobre el tipo de consulta que queremos recibir.
          </p>
        </div>

        <form class="mt-8 grid gap-4 sm:grid-cols-2">
          <label class="grid gap-2 text-sm font-medium text-slate-800">
            Nombre
            <input type="text" placeholder="Tu nombre" class="rounded-2xl border border-red-100 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-[#e1062c]" />
          </label>

          <label class="grid gap-2 text-sm font-medium text-slate-800">
            Empresa
            <input type="text" placeholder="Nombre de la empresa" class="rounded-2xl border border-red-100 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-[#e1062c]" />
          </label>

          <label class="grid gap-2 text-sm font-medium text-slate-800">
            Email
            <input type="email" placeholder="tu@email.com" class="rounded-2xl border border-red-100 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-[#e1062c]" />
          </label>

          <label class="grid gap-2 text-sm font-medium text-slate-800">
            Teléfono
            <input type="tel" placeholder="600 000 000" class="rounded-2xl border border-red-100 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-[#e1062c]" />
          </label>

          <label class="grid gap-2 text-sm font-medium text-slate-800 sm:col-span-2">
            Qué necesitas
            <textarea rows="5" placeholder="Escribe aquí un texto random que luego sustituiremos por el contenido definitivo" class="rounded-[1.5rem] border border-red-100 bg-white px-4 py-3 text-sm text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-[#e1062c]"></textarea>
          </label>

          <div class="sm:col-span-2">
            <button type="submit" class="brand-button">Enviar solicitud</button>
          </div>
        </form>
      </div>

      <aside class="rounded-[2rem] border border-red-100 bg-white p-6 shadow-sm sm:p-8">
        <p class="brand-eyebrow">Antes de enviar</p>
        <h2 class="mt-3 text-2xl font-extrabold tracking-tight text-slate-900">Un pequeño bloque de apoyo</h2>
        <p class="mt-4 text-sm leading-7 text-slate-700">
          Texto placeholder para acompañar el formulario con una explicación simple. Aquí luego podemos añadir confianza, una promesa de respuesta o una nota comercial muy breve.
        </p>

        <ul class="mt-6 grid gap-3 text-sm text-slate-700">
          <li class="flex gap-3 rounded-2xl border border-red-100 bg-red-50/60 p-4"><span class="brand-check">✓</span><span>Texto random para una ventaja o mensaje corto.</span></li>
          <li class="flex gap-3 rounded-2xl border border-red-100 bg-red-50/60 p-4"><span class="brand-check">✓</span><span>Texto de ejemplo para indicar el siguiente paso.</span></li>
          <li class="flex gap-3 rounded-2xl border border-red-100 bg-red-50/60 p-4"><span class="brand-check">✓</span><span>Texto temporal que después cambiaremos por uno real.</span></li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="container pb-16 sm:pb-20">
    <div class="rounded-[2rem] border border-red-100 bg-white p-6 shadow-sm sm:p-8 lg:p-10">
      <div class="max-w-3xl">
        <p class="brand-eyebrow">Delegaciones</p>
        <h2 class="mt-3 text-2xl font-extrabold tracking-tight text-slate-900 sm:text-3xl lg:text-4xl">
          Debajo del formulario, un bloque muy simple para hablar de delegaciones
        </h2>
        <p class="mt-4 text-base leading-7 text-slate-700 sm:text-lg">
          Texto random para introducir las delegaciones. La idea es que este bloque quede limpio: una breve explicación arriba y tarjetas sencillas debajo para que luego podamos rellenarlo con el contenido bueno.
        </p>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {delegations.map((delegation) => (
          <article class="brand-card h-full">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#b40422]">{delegation.area}</p>
            <h3 class="mt-3 text-xl font-bold text-slate-900">{delegation.city}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-700">{delegation.text}</p>
            <a href="/delegaciones" class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-[#b40422] transition hover:text-[#e1062c]">
              Ver más
              <span aria-hidden="true">→</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
