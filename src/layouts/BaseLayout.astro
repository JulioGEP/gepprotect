---
import Nav from '../components/Nav.astro';
import '../styles.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const footerLinks = [
  { href: '/servicios', label: 'Servicios PCI' },
  { href: '/sectores', label: 'Sectores' },
  { href: '/normativa', label: 'Normativa PCI' },
  { href: '/casos-de-exito', label: 'Casos de éxito' },
  { href: '/delegaciones', label: 'Delegaciones' },
  { href: '/contacto', label: 'Contacto' },
];

---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/png" href="/GEP_Logo_Icono_ROJO.png" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <footer class="border-t border-red-100 bg-white">
      <div class="container grid gap-10 py-10 lg:grid-cols-[1.1fr_0.9fr]">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#b40422]">GEP Protect</p>
          <h2 class="mt-4 text-2xl font-extrabold tracking-tight text-slate-900">Protección contra incendios para empresas con foco en claridad, cumplimiento y continuidad.</h2>
          <p class="mt-4 max-w-xl text-sm leading-7 text-slate-600">
            Arquitectura SEO y mensajes pensados para instalación, mantenimiento, adecuación normativa, sectores y captación local sin depender de una home excesivamente visual.
          </p>
        </div>

        <div>
          <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-900">Menu</h3>
          <ul class="mt-4 grid gap-3 text-sm text-slate-600">
            {footerLinks.map((link) => (
              <li>
                <a href={link.href} class="transition hover:text-[#e1062c]">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <div class="border-t border-red-100 bg-red-50/50">
        <div class="container flex flex-col gap-3 py-5 text-sm text-slate-600 sm:flex-row sm:items-center sm:justify-between">
          <p class="font-semibold text-slate-800">GEP Protect · Grupo GEP</p>
          <p>Diseño base alineado con una navegación interior pensada para SEO, UX y captación orgánica.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
