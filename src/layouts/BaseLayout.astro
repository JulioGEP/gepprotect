---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SeoHead from '../components/SeoHead.astro';
import StickyCtaButton from '../components/StickyCtaButton.astro';

interface Props {
  title: string;
  description: string;
  schema?: Record<string, unknown> | Array<Record<string, unknown>>;
  type?: 'website' | 'article';
}

const { title, description, schema, type = 'website' } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SeoHead title={title} description={description} schema={schema} type={type} />
    {import.meta.env.PUBLIC_ANALYTICS_DOMAIN && (
      <script defer data-domain={import.meta.env.PUBLIC_ANALYTICS_DOMAIN} src="https://plausible.io/js/script.js"></script>
    )}
  </head>
  <body>
    <Header />
    <main class="max-w-6xl mx-auto px-4">
      <slot />
    </main>
    <Footer />
    <StickyCtaButton />
  </body>
</html>
