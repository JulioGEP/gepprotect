---
import { company } from '../data/site';
---
<footer class="bg-[#0f0f10] text-white">
  <div class="mx-auto grid w-full max-w-6xl gap-10 px-4 py-14 md:grid-cols-4">
    <div>
      <p class="text-lg font-bold">GEP</p>
      <p class="mt-3 text-sm text-zinc-300">Ingeniería de protección contra incendios, mantenimiento y cumplimiento normativo.</p>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-zinc-400">Servicios</p>
      <ul class="mt-3 space-y-2 text-sm text-zinc-200">
        <li><a href="/servicios/">Instalación PCI</a></li>
        <li><a href="/servicios/mantenimiento-pci/">Mantenimiento</a></li>
        <li><a href="/servicios/deteccion-incendios/">Detección</a></li>
        <li><a href="/servicios/extincion-automatica/">Extinción</a></li>
      </ul>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-zinc-400">Empresa</p>
      <ul class="mt-3 space-y-2 text-sm text-zinc-200">
        <li><a href="/">Inicio</a></li>
        <li><a href="/casos-de-exito/">Casos de éxito</a></li>
        <li><a href="/contacto/">Contacto</a></li>
      </ul>
    </div>

    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-zinc-400">Contacto</p>
      <ul class="mt-3 space-y-2 text-sm text-zinc-200">
        <li>{company.address}</li>
        <li><a href={company.phoneHref}>{company.phone}</a></li>
        <li><a href={`mailto:${company.email}`}>{company.email}</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto flex w-full max-w-6xl flex-col gap-2 px-4 py-5 text-xs text-zinc-400 md:flex-row md:items-center md:justify-between">
      <p>© 2026 GEP Protect. Todos los derechos reservados.</p>
      <div class="flex gap-4">
        <a href="#">Aviso legal</a>
        <a href="#">Política de privacidad</a>
        <a href="#">Cookies</a>
      </div>
    </div>
  </div>
</footer>
