---
interface Props {
  eyebrow: string;
  title: string;
  summary: string;
  focus: string;
  sections: Array<{ title: string; text: string }>;
}

const { eyebrow, title, summary, focus, sections } = Astro.props;
---

<section class="container py-12 sm:py-16">
  <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand-600">{eyebrow}</p>
  <h1 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">{title}</h1>
  <p class="mt-5 max-w-3xl text-lg text-slate-700">{summary}</p>

  <div class="mt-8 rounded-2xl border border-brand-100 bg-brand-50 p-6">
    <h2 class="text-lg font-semibold text-brand-700">Foco SEO/Captación</h2>
    <p class="mt-2 text-slate-700">{focus}</p>
  </div>

  <div class="mt-10 grid gap-5 sm:grid-cols-2">
    {sections.map((section) => (
      <article class="rounded-2xl border border-slate-200 bg-white p-6">
        <h3 class="text-base font-semibold text-slate-900">{section.title}</h3>
        <p class="mt-2 text-sm leading-6 text-slate-700">{section.text}</p>
      </article>
    ))}
  </div>
</section>
