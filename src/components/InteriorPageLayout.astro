---
interface ActionLink {
  href: string;
  label: string;
}

interface ValueItem {
  title: string;
  text: string;
}

interface CoreBlock {
  title: string;
  text: string;
  bullets?: string[];
}

interface UseCase {
  title: string;
  text: string;
  bullets?: string[];
}

interface ProofItem {
  highlight: string;
  title: string;
  text: string;
}

interface ComparisonRow {
  topic: string;
  ours: string;
  alternative: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  eyebrow: string;
  title: string;
  intro: string;
  audience: string;
  benefit: string;
  miniCta: ActionLink;
  valueTitle: string;
  valueItems: ValueItem[];
  core: {
    title: string;
    intro: string;
    blocks: CoreBlock[];
  };
  useCases: {
    title: string;
    intro: string;
    items: UseCase[];
  };
  visual: {
    title: string;
    text: string;
    image: string;
    alt: string;
  };
  differentiators: {
    title: string;
    intro: string;
    items: ValueItem[];
  };
  proof: {
    title: string;
    intro: string;
    items: ProofItem[];
  };
  comparison: {
    title: string;
    intro: string;
    rows: ComparisonRow[];
  };
  faqs: FaqItem[];
  finalCta: {
    title: string;
    text: string;
    primary: ActionLink;
    secondary?: ActionLink;
  };
  related: {
    title: string;
    links: Array<ActionLink & { description: string }>;
  };
}

const {
  eyebrow,
  title,
  intro,
  audience,
  benefit,
  miniCta,
  valueTitle,
  valueItems,
  core,
  useCases,
  visual,
  differentiators,
  proof,
  comparison,
  faqs,
  finalCta,
  related,
} = Astro.props;

const canonicalBase = Astro.site ?? new URL('https://gepprotect.netlify.app');
const pageUrl = new URL(Astro.url.pathname, canonicalBase).toString();

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: new URL('/', canonicalBase).toString(),
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: title,
      item: pageUrl,
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section class="container interior-intro py-12 sm:py-16">
  <div class="max-w-4xl">
    <p class="brand-eyebrow">{eyebrow}</p>
    <h1 class="mt-4 max-w-4xl text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-[3.4rem] lg:leading-[1.05]">
      {title}
    </h1>
    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-700">
      {intro}
    </p>
    <div class="mt-5 flex flex-wrap gap-3 text-sm text-slate-600">
      <span class="inline-flex items-center rounded-full border border-red-200 bg-white px-3 py-1.5 font-medium text-slate-700">
        <strong class="mr-2 text-slate-900">Para quién:</strong>{audience}
      </span>
      <span class="inline-flex items-center rounded-full border border-red-200 bg-white px-3 py-1.5 font-medium text-slate-700">
        <strong class="mr-2 text-slate-900">Beneficio:</strong>{benefit}
      </span>
    </div>
    <a href={miniCta.href} class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-[#b40422] transition hover:text-[#e1062c]">
      {miniCta.label}
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<section class="container pb-12 sm:pb-16">
  <div class="rounded-[2rem] border border-red-100 bg-white p-8 shadow-sm">
    <div class="max-w-3xl">
      <p class="brand-eyebrow">Valor inmediato</p>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">{valueTitle}</h2>
    </div>
    <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {valueItems.map((item) => (
        <article class="brand-card h-full">
          <h3 class="text-lg font-bold text-slate-900">{item.title}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-700">{item.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="container pb-12 sm:pb-16">
  <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-start">
    <div>
      <p class="brand-eyebrow">Core SEO</p>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">{core.title}</h2>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-700">{core.intro}</p>
      <div class="mt-8 grid gap-4">
        {core.blocks.map((block) => (
          <article class="brand-card">
            <h3 class="text-xl font-bold text-slate-900">{block.title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-700">{block.text}</p>
            {block.bullets && (
              <ul class="mt-4 grid gap-2 text-sm text-slate-700">
                {block.bullets.map((bullet) => (
                  <li class="flex gap-3">
                    <span class="brand-check">✓</span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </div>
    </div>

    <aside class="space-y-4 lg:sticky lg:top-24">
      <div class="rounded-[2rem] border border-red-100 bg-red-50 p-6 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#b40422]">Lectura rápida</p>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-slate-700">
          <li class="flex gap-3"><span class="brand-check">1</span><span>Mensaje directo desde el primer scroll, sin hero ni distracciones.</span></li>
          <li class="flex gap-3"><span class="brand-check">2</span><span>Bloques escaneables para búsquedas transaccionales e informacionales.</span></li>
          <li class="flex gap-3"><span class="brand-check">3</span><span>CTA progresiva: primero aclarar, después convertir.</span></li>
        </ul>
      </div>
      <div class="rounded-[2rem] border border-red-100 bg-white p-6 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#b40422]">Mini CTA</p>
        <p class="mt-3 text-sm leading-6 text-slate-700">
          Si ya tienes una necesidad definida, podemos aterrizarla en una revisión inicial y una propuesta accionable.
        </p>
        <a href={finalCta.primary.href} class="brand-button mt-5 w-full">{finalCta.primary.label}</a>
      </div>
    </aside>
  </div>
</section>

<section class="container pb-12 sm:pb-16">
  <div class="rounded-[2rem] border border-red-100 bg-white p-8 shadow-sm">
    <div class="max-w-3xl">
      <p class="brand-eyebrow">Casos de uso</p>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">{useCases.title}</h2>
      <p class="mt-5 text-lg leading-8 text-slate-700">{useCases.intro}</p>
    </div>
    <div class="mt-8 grid gap-4 lg:grid-cols-2">
      {useCases.items.map((item) => (
        <article class="brand-card h-full">
          <h3 class="text-xl font-bold text-slate-900">{item.title}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-700">{item.text}</p>
          {item.bullets && (
            <ul class="mt-4 grid gap-2 text-sm text-slate-700">
              {item.bullets.map((bullet) => (
                <li class="flex gap-3">
                  <span class="brand-check">✓</span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<section class="container pb-12 sm:pb-16">
  <div class="grid gap-8 rounded-[2rem] border border-red-100 bg-red-50/70 p-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
    <figure class="overflow-hidden rounded-[2rem] border border-red-100 bg-white shadow-sm">
      <img src={visual.image} alt={visual.alt} class="h-full min-h-[320px] w-full object-cover" loading="lazy" />
    </figure>
    <div>
      <p class="brand-eyebrow">Bloque visual</p>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">{visual.title}</h2>
      <p class="mt-5 text-lg leading-8 text-slate-700">{visual.text}</p>
    </div>
  </div>
</section>

<section class="container pb-12 sm:pb-16">
  <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
    <div>
      <p class="brand-eyebrow">Por qué GEP Protect</p>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">{differentiators.title}</h2>
      <p class="mt-5 text-lg leading-8 text-slate-700">{differentiators.intro}</p>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      {differentiators.items.map((item) => (
        <article class="brand-card h-full">
          <h3 class="text-lg font-bold text-slate-900">{item.title}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-700">{item.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="container pb-12 sm:pb-16">
  <div class="rounded-[2rem] border border-red-100 bg-white p-8 shadow-sm">
    <div class="max-w-3xl">
      <p class="brand-eyebrow">Prueba social</p>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">{proof.title}</h2>
      <p class="mt-5 text-lg leading-8 text-slate-700">{proof.intro}</p>
    </div>
    <div class="mt-8 grid gap-4 lg:grid-cols-3">
      {proof.items.map((item) => (
        <article class="brand-card h-full">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[#b40422]">{item.highlight}</p>
          <h3 class="mt-3 text-lg font-bold text-slate-900">{item.title}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-700">{item.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="container pb-12 sm:pb-16">
  <div class="rounded-[2rem] border border-red-100 bg-white p-8 shadow-sm">
    <div class="max-w-3xl">
      <p class="brand-eyebrow">Comparativa y objeciones</p>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">{comparison.title}</h2>
      <p class="mt-5 text-lg leading-8 text-slate-700">{comparison.intro}</p>
    </div>

    <div class="mt-8 overflow-hidden rounded-2xl border border-red-100">
      <table class="w-full border-collapse bg-white text-left text-sm text-slate-700">
        <thead class="bg-red-50 text-slate-900">
          <tr>
            <th class="px-4 py-3 font-semibold">Criterio</th>
            <th class="px-4 py-3 font-semibold">GEP Protect</th>
            <th class="px-4 py-3 font-semibold">Alternativa estándar</th>
          </tr>
        </thead>
        <tbody>
          {comparison.rows.map((row) => (
            <tr class="border-t border-red-100 align-top">
              <th class="px-4 py-3 font-semibold text-slate-900">{row.topic}</th>
              <td class="px-4 py-3">{row.ours}</td>
              <td class="px-4 py-3">{row.alternative}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-8 grid gap-4 lg:grid-cols-2">
      {faqs.map((faq) => (
        <article class="rounded-2xl border border-slate-200 p-5">
          <h3 class="text-base font-bold text-slate-900">{faq.question}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-700">{faq.answer}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="container pb-12 sm:pb-16">
  <div class="rounded-[2rem] border border-red-100 bg-[#141414] p-8 text-white shadow-sm">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-red-200">CTA principal</p>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight sm:text-4xl">{finalCta.title}</h2>
      <p class="mt-5 text-lg leading-8 text-slate-200">{finalCta.text}</p>
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href={finalCta.primary.href} class="brand-button">{finalCta.primary.label}</a>
      {finalCta.secondary && (
        <a href={finalCta.secondary.href} class="rounded-full border border-white/20 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-white/10">
          {finalCta.secondary.label}
        </a>
      )}
    </div>
  </div>
</section>

<section class="container pb-14 sm:pb-20">
  <div class="rounded-[2rem] border border-red-100 bg-white p-8 shadow-sm">
    <div class="max-w-3xl">
      <p class="brand-eyebrow">Interlinking estratégico</p>
      <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl">{related.title}</h2>
    </div>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {related.links.map((link) => (
        <a href={link.href} class="brand-card block h-full transition hover:-translate-y-0.5 hover:shadow-md">
          <h3 class="text-lg font-bold text-slate-900">{link.label}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-700">{link.description}</p>
          <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-[#b40422]">
            Ver contenido
            <span aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
