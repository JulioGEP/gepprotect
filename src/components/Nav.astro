---
const links = [
  { href: '/', label: 'Inicio' },
  { href: '/servicios', label: 'Servicios' },
  { href: '/sectores', label: 'Sectores' },
  { href: '/normativa', label: 'Normativa' },
  { href: '/casos-de-exito', label: 'Casos de éxito' },
  { href: '/contacto', label: 'Contacto' },
];

const { pathname } = Astro.url;
---

<header class="sticky top-0 z-50 border-b border-red-100 bg-white/95 backdrop-blur">
  <div class="container flex flex-wrap items-center justify-between gap-4 py-4">
    <a href="/" class="flex items-end gap-2">
      <span class="text-3xl font-extrabold tracking-tight text-[#e1062c]">GEP</span>
      <span class="pb-1 text-xs font-medium uppercase tracking-[0.15em] text-slate-600">Protect</span>
    </a>
    <nav aria-label="Navegación principal">
      <ul class="flex flex-wrap items-center gap-2 text-sm font-medium sm:gap-3">
        {links.map((link) => {
          const isActive = pathname === link.href;
          return (
            <li>
              <a
                href={link.href}
                class:list={[
                  'rounded-full px-3 py-1.5 transition',
                  isActive
                    ? 'bg-[#e1062c] text-white'
                    : 'text-slate-700 hover:bg-red-50 hover:text-[#e1062c]',
                ]}
                aria-current={isActive ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>
