---
import { company } from '../data/site';
---
<div
  id="sticky-cta"
  class="pointer-events-none fixed bottom-6 right-5 z-50 flex flex-col items-end gap-2 opacity-0 transition-all duration-300 ease-out lg:bottom-8 lg:right-8"
  aria-hidden="true"
>
  <a
    href="#cta-final"
    class="flex items-center gap-2 rounded-full bg-[#E4032D] px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-[#E4032D]/40 transition hover:bg-[#c70426] hover:shadow-[#E4032D]/60"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
    Solicitar visita técnica
  </a>
  <a
    href={company.phoneHref}
    class="flex items-center gap-1.5 rounded-full border border-zinc-200 bg-white px-4 py-2 text-xs font-semibold text-zinc-700 shadow-md transition hover:border-[#E4032D]/40 hover:text-[#E4032D]"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
    </svg>
    {company.phone}
  </a>
</div>

<script>
  const el = document.getElementById('sticky-cta');
  if (el) {
    const firstSection = document.querySelector('main > section');

    function update() {
      const heroBottom = firstSection ? firstSection.getBoundingClientRect().bottom : -1;
      const pastHero = heroBottom < 0;
      el!.classList.toggle('opacity-0', !pastHero);
      el!.classList.toggle('pointer-events-none', !pastHero);
      el!.classList.toggle('translate-y-2', !pastHero);
      el!.setAttribute('aria-hidden', String(!pastHero));
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>
